meta {
  name: Unsubscribe Order Update
  type: websocket
  seq: 17
}

websocket {
  url: ws://127.0.0.1:8765
  description: Unsubscribe from order_update events
}

message:json {
  {
    "action": "unsubscribe",
    "channel": "order_update"
  }
}

docs {
  Server responds with:
  {"type": "unsubscribe", "channel": "order_update", "status": "success"}
}
